# Pigeon — root environment. Copy to `.env` (git-ignored) and fill in.
# The backend reads this at startup. Config is validated per-feature as it
# lands; today the baseline validates the keys below.

# API port (backend server).
PORT=8788

# Worker heartbeat cadence (ms).
WORKER_HEARTBEAT_INTERVAL_MS=30000

# Postgres connection string. In development this defaults to the
# docker-compose value when absent
# (postgres://pigeon:pigeon@localhost:5432/pigeon), so you can leave it
# commented for `pnpm dev` + the embedded-postgres test harness. It is
# REQUIRED in production and in CI / NODE_ENV=production|test — set it to
# match POSTGRES_PASSWORD when running the composed stack on a server.
# DATABASE_URL=postgres://pigeon:CHANGE_ME@db:5432/pigeon

# Logging verbosity (trace | debug | info | warn | error). Defaults to info.
# LOG_LEVEL=info

# Host the API binds to. Defaults to 0.0.0.0.
# HOST=0.0.0.0
