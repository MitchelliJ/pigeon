# Pigeon configuration. Copy to .env and fill in. Every service (server,
# worker, migrations) reads the same file; secrets marked (!) are never logged.

# --- Core ---------------------------------------------------------------
NODE_ENV=development
HOST=0.0.0.0
PORT=8788
LOG_LEVEL=info
# (!) Postgres connection string. `pnpm dev:db` serves this locally without Docker.
DATABASE_URL=postgres://pigeon:pigeon@localhost:5433/pigeon
WORKER_HEARTBEAT_INTERVAL_MS=30000

# (!) 32 random bytes, base64. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
VAULT_MASTER_KEY=
# (!) Long random string used to sign session tokens.
SESSION_SECRET=

# Public origins (used for CORS, OAuth redirects, webhook URLs).
WEB_ORIGIN=http://localhost:4321
API_ORIGIN=http://localhost:8788

# --- Optional integrations ----------------------------------------------
# Leave any of these empty and the related feature runs in mock/hidden mode.

# (!) Mistral — real LLM summaries. Empty = deterministic mock summarizer.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# (!) Mollie payments (test_... or live_...). Empty = billing sandbox mode.
MOLLIE_API_KEY=

# (!) Gmail OAuth (Google Cloud console). Empty = Gmail OAuth hidden.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# (!) Microsoft OAuth (Entra app). Empty = Microsoft OAuth hidden.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# (!) WhatsApp Business Cloud API. Empty = WhatsApp channel hidden.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# signal-cli-rest-api endpoint. Empty = Signal channel hidden.
SIGNAL_API_URL=
SIGNAL_SENDER_NUMBER=
