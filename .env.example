# Pigeon — root environment. Copy to `.env` (git-ignored) and fill in.
# The backend reads this at startup. Config is validated per-feature as it
# lands; today the baseline validates the keys below.

# API port (backend server).
PORT=8788

# Worker heartbeat cadence (ms).
WORKER_HEARTBEAT_INTERVAL_MS=30000

# How often the worker polls for queued jobs to claim and run (ms). Optional
# — defaults to 5000.
# WORKER_POLL_INTERVAL_MS=5000

# Max number of jobs the worker claims and runs concurrently per poll tick.
# Optional — defaults to 5.
# WORKER_CONCURRENCY=5

# How often the scheduler checks which mailboxes are due for a sync (ms).
# Optional — defaults to 60000.
# SCHEDULER_INTERVAL_MS=60000

# Postgres connection string. In development this defaults to the
# docker-compose value when absent
# (postgres://pigeon:pigeon@localhost:5432/pigeon), so you can leave it
# commented for `pnpm dev` + the embedded-postgres test harness. It is
# REQUIRED in production and in CI / NODE_ENV=production|test — set it to
# match POSTGRES_PASSWORD when running the composed stack on a server.
# DATABASE_URL=postgres://pigeon:CHANGE_ME@db:5432/pigeon

# Logging verbosity (trace | debug | info | warn | error). Defaults to info.
# LOG_LEVEL=info

# Host the API binds to. Defaults to 0.0.0.0.
# HOST=0.0.0.0

# Base URL of the web app, used to build links in outgoing mail (e.g. the
# verification/reset links). In development this defaults to
# http://localhost:4321, so you can leave it commented for `pnpm dev`. It is
# REQUIRED in production.
# APP_BASE_URL=http://localhost:4321

# Sender address for outgoing mail (name + address). Optional in dev/test;
# REQUIRED in production.
# MAIL_FROM=Pigeon <noreply@pigeon.email>

# Resend API key. Secret — never echoed by describeConfig. Optional in
# dev/test — the mock mail provider logs verification/reset links to stdout
# when this is absent; REQUIRED in production.
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Whether new sign-ups are accepted ("true" | "false"). Defaults to false.
# SIGNUP_OPEN=false

# Vault master key: base64-encoded 32 random bytes (AES-256), used to seal
# provider credentials (IMAP passwords, OAuth tokens, webhook secrets) at
# rest. Secret — never echoed by describeConfig. REQUIRED in every
# environment, including development. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# VAULT_MASTER_KEY=

# Timeout (ms) for opening a connection to a mailbox provider. Optional —
# defaults to 10000.
# MAILBOX_CONNECT_TIMEOUT_MS=10000
